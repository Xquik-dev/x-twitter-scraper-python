#!/usr/bin/env bash

# SPDX-FileCopyrightText: 2026 Xquik contributors
#
# SPDX-License-Identifier: Apache-2.0

set -euo pipefail

cd "$(dirname "$0")/.."

audit_requirements="$(mktemp "${TMPDIR:-/tmp}/xquik-python-audit.XXXXXX")"
trap 'rm -f -- "$audit_requirements"' EXIT

echo "==> Exporting locked third-party dependencies"
uv export \
  --quiet \
  --locked \
  --all-extras \
  --group pydantic-v2 \
  --no-emit-project \
  --format requirements-txt \
  --output-file "$audit_requirements"

echo "==> Auditing locked third-party dependencies"
uvx --from pip-audit==2.10.1 pip-audit \
  --strict \
  --disable-pip \
  --require-hashes \
  --requirement "$audit_requirements"
